# Aegis NetSec - Local Detection Rules

# 1. Threat Intel IP Matches
alert ip [185.220.101.5,45.227.254.12,198.51.100.45] any -> any any (msg:"Aegis Alert: Communication with Flagged Threat Intel IP"; sid:2000001; rev:1;)
alert ip any any -> [185.220.101.5,45.227.254.12,198.51.100.45] any (msg:"Aegis Alert: Communication with Flagged Threat Intel IP"; sid:2000002; rev:1;)

# 2. Threat Intel Domain Queries (DNS)
alert dns any any -> any any (msg:"Aegis Alert: DNS Query for Flagged Malware C2 Domain (evil-c2-domain.net)"; dns.query; content:"evil-c2-domain.net"; nocase; sid:2000003; rev:1;)
alert dns any any -> any any (msg:"Aegis Alert: DNS Query for Flagged Cryptominer Domain (malware-c2-server.com)"; dns.query; content:"malware-c2-server.com"; nocase; sid:2000004; rev:1;)

# 3. Generic Diagnostic Alerts (Useful for verifying live capture)
alert icmp any any -> any any (msg:"Aegis Alert: ICMP Ping Packet Detected"; sid:2000005; rev:1;)
alert http any any -> any any (msg:"Aegis Alert: HTTP GET Request Detected"; http.method; content:"GET"; sid:2000006; rev:1;)
alert tls any any -> any any (msg:"Aegis Alert: TLS Traffic Detected"; sid:2000007; rev:1;)
